<Window x:Class="Woobly.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Woobly"
        xmlns:converters="clr-namespace:Woobly.Converters"
        mc:Ignorable="d"
        Title="Woobly"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="400"
        Height="200"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded"
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="HighQuality"
        RenderOptions.EdgeMode="Aliased">
    
    <Window.Resources>
        <converters:PageIndexToBrushConverter x:Key="PageIndexToBrushConverter"/>
    </Window.Resources>
    
    <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="IslandScaleTransform" ScaleX="0.375" ScaleY="0.2"/>
                <TranslateTransform x:Name="IslandTranslateTransform" Y="0"/>
            </TransformGroup>
        </Grid.RenderTransform>
        
        <Border x:Name="MainBorder"
                Width="400"
                Height="200"
                CornerRadius="22"
                BorderThickness="1"
                ClipToBounds="True">
            <!-- Glassmorphism Background -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#E61A1A1A" Offset="0"/>
                    <GradientStop Color="#E6202020" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            
            <!-- Subtle border glow -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#55FFFFFF" Offset="0"/>
                    <GradientStop Color="#22FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#552D9CDB" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            
            <!-- Enhanced drop shadow -->
            <Border.Effect>
                <DropShadowEffect Color="#000000" 
                                BlurRadius="30" 
                                ShadowDepth="0" 
                                Opacity="0.6"/>
            </Border.Effect>
            
            <Grid x:Name="ContentGrid" Width="400" Height="200" ClipToBounds="True">
                <!-- Collapsed State Content -->
                <StackPanel x:Name="CollapsedContent" 
                           Orientation="Horizontal"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           Opacity="1"
                           RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <ScaleTransform x:Name="CollapsedContentScale" ScaleX="2.667" ScaleY="5.0"/>
                    </StackPanel.RenderTransform>
                    <TextBlock Text="{Binding SystemInfo.FormattedTime}"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              FontSize="12"
                              FontWeight="SemiBold"
                              Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SystemInfo.Temperature, StringFormat={}{0:0}°}"
                              Foreground="{StaticResource SecondaryTextBrush}"
                              FontSize="12"
                              Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SystemInfo.BatteryPercentage, StringFormat={}{0}%}"
                              Foreground="{StaticResource SecondaryTextBrush}"
                              FontSize="12"/>
                </StackPanel>
                
                <!-- Expanded State Content -->
                <Grid x:Name="ExpandedContent" Visibility="Collapsed" Opacity="0">
                    <!-- Page Container -->
                    <Grid x:Name="PageContainer" Margin="15">
                        
                        <!-- Page 1: System Overview -->
                        <StackPanel x:Name="Page1" Visibility="Visible" RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </StackPanel.RenderTransform>
                            <TextBlock Text="{Binding SystemInfo.FormattedTime}"
                                      Foreground="{StaticResource PrimaryTextBrush}"
                                      FontSize="36"
                                      FontWeight="Light"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SystemInfo.FormattedDate}"
                                      Foreground="{StaticResource SecondaryTextBrush}"
                                      FontSize="13"
                                      HorizontalAlignment="Center"
                                      Margin="0,4,0,20"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <StackPanel Margin="15,0">
                                    <TextBlock Text="Weather"
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontSize="10"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SystemInfo.Temperature, StringFormat={}{0:0}°C}"
                                              Foreground="{StaticResource PrimaryTextBrush}"
                                              FontSize="20"
                                              FontWeight="SemiBold"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="15,0">
                                    <TextBlock Text="Battery"
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontSize="10"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SystemInfo.BatteryPercentage, StringFormat={}{0}%}"
                                              Foreground="{StaticResource PrimaryTextBrush}"
                                              FontSize="20"
                                              FontWeight="SemiBold"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Page 2: Media Context -->
                        <StackPanel x:Name="Page2" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </StackPanel.RenderTransform>
                            <TextBlock Text="No Media Playing"
                                      Foreground="{StaticResource TertiaryTextBrush}"
                                      FontSize="13"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="0,70,0,0"
                                      Visibility="{Binding MediaInfo.IsAvailable, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            
                            <StackPanel Visibility="{Binding MediaInfo.IsAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Margin="0,10,0,0">
                                <TextBlock Text="{Binding MediaInfo.Title}"
                                          Foreground="{StaticResource PrimaryTextBrush}"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          TextTrimming="CharacterEllipsis"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding MediaInfo.Artist}"
                                          Foreground="{StaticResource SecondaryTextBrush}"
                                          FontSize="12"
                                          TextTrimming="CharacterEllipsis"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,15"/>
                                
                                <!-- Modern Progress Bar -->
                                <Border Background="{StaticResource SecondaryBackgroundBrush}"
                                       Height="4"
                                       CornerRadius="2"
                                       Margin="20,0">
                                    <Rectangle Fill="{StaticResource AccentBrush}"
                                              HorizontalAlignment="Left"
                                              RadiusX="2"
                                              RadiusY="2">
                                        <Rectangle.Width>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:PercentageWidthConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="MediaInfo.ProgressPercentage"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </Rectangle.Width>
                                    </Rectangle>
                                </Border>
                                
                                <StackPanel Orientation="Horizontal" 
                                          HorizontalAlignment="Center"
                                          Margin="0,8,0,0">
                                    <TextBlock Text="{Binding MediaInfo.FormattedPosition}"
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontSize="10"/>
                                    <TextBlock Text=" / "
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontSize="10"/>
                                    <TextBlock Text="{Binding MediaInfo.FormattedDuration}"
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Page 3: AI Response -->
                        <Grid x:Name="Page3" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <StackPanel>
                                <TextBox x:Name="AIInputBox"
                                        Background="#242424"
                                        Foreground="#FFFFFF"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"
                                        Padding="12,10"
                                        FontSize="12"
                                        CaretBrush="#2D9CDB"
                                        SelectionBrush="#2D9CDB"
                                        TextWrapping="Wrap"
                                        Height="40"
                                        Margin="0,0,0,10"
                                        VerticalContentAlignment="Center"
                                        KeyDown="AIInputBox_KeyDown">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding AIResponse}"
                                              Foreground="{StaticResource SecondaryTextBrush}"
                                              FontSize="11"
                                              TextWrapping="Wrap"
                                              Padding="5"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Page 4: Task Memory -->
                        <Grid x:Name="Page4" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <StackPanel>
                                <TextBox x:Name="TaskInputBox"
                                        Background="#242424"
                                        Foreground="#FFFFFF"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"
                                        Padding="12,10"
                                        FontSize="12"
                                        CaretBrush="#2D9CDB"
                                        SelectionBrush="#2D9CDB"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,10"
                                        KeyDown="TaskInputBox_KeyDown">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <ScrollViewer Height="140" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Tasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                                    <CheckBox IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                                             Style="{StaticResource ModernCheckBox}"
                                                             VerticalAlignment="Center"
                                                             Click="TaskCheckBox_Click"/>
                                                    <TextBlock Text="{Binding Content}"
                                                              Foreground="{StaticResource PrimaryTextBrush}"
                                                              FontSize="11"
                                                              Margin="5,0"
                                                              VerticalAlignment="Center"
                                                              TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethroughConverter}}"/>
                                                    <Button Content="×"
                                                           Style="{StaticResource ModernDeleteButton}"
                                                           Click="RemoveTask_Click"
                                                           Tag="{Binding Id}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Page 5: Clipboard Memory -->
                        <Grid x:Name="Page5" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ClipboardItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ModernClipboardItem}"
                                                   MouseDown="ClipboardItem_MouseDown"
                                                   Tag="{Binding Content}">
                                                <TextBlock Text="{Binding Preview}"
                                                          Foreground="{StaticResource PrimaryTextBrush}"
                                                          FontSize="11"
                                                          TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                        
                        <!-- Page 6: Settings -->
                        <ScrollViewer x:Name="Page6" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" RenderTransformOrigin="0.5,0.5">
                            <ScrollViewer.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </ScrollViewer.RenderTransform>
                            <StackPanel>
                                <TextBlock Text="AI Settings" 
                                          Foreground="{StaticResource PrimaryTextBrush}" 
                                          FontSize="13" 
                                          FontWeight="SemiBold" 
                                          Margin="0,0,0,8"/>
                                <TextBlock Text="Model:" 
                                          Foreground="{StaticResource TertiaryTextBrush}" 
                                          FontSize="10"
                                          Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.OpenRouterModel, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#242424"
                                        Foreground="#FFFFFF"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"
                                        Padding="12,10"
                                        FontSize="12"
                                        CaretBrush="#2D9CDB"
                                        SelectionBrush="#2D9CDB"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,10">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <TextBlock Text="API Key:" 
                                          Foreground="{StaticResource TertiaryTextBrush}" 
                                          FontSize="10"
                                          Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.OpenRouterApiKey, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#242424"
                                        Foreground="#FFFFFF"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"
                                        Padding="12,10"
                                        FontSize="12"
                                        CaretBrush="#2D9CDB"
                                        SelectionBrush="#2D9CDB"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,15">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                
                                <TextBlock Text="Weather Settings" 
                                          Foreground="{StaticResource PrimaryTextBrush}" 
                                          FontSize="13" 
                                          FontWeight="SemiBold" 
                                          Margin="0,0,0,8"/>
                                <TextBlock Text="City:" 
                                          Foreground="{StaticResource TertiaryTextBrush}" 
                                          FontSize="10"
                                          Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.City, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#242424"
                                        Foreground="#FFFFFF"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"
                                        Padding="12,10"
                                        FontSize="12"
                                        CaretBrush="#2D9CDB"
                                        SelectionBrush="#2D9CDB"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,15">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                
                                <Button Content="Save Settings"
                                       Style="{StaticResource ModernButton}"
                                       Click="SaveSettings_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                        
                    </Grid>
                    
                    <!-- Page Navigation Dots -->
                    <StackPanel Orientation="Horizontal" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,10">
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=0}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect x:Name="Dot0Glow" 
                                                Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=1}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="1"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=2}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="2"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=3}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="3"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=4}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="4"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=5}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="5"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
