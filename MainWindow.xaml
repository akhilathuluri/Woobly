<Window x:Class="Woobly.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Woobly"
        xmlns:converters="clr-namespace:Woobly.Converters"
        mc:Ignorable="d"
        Title="Woobly"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="400"
        Height="200"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded"
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="HighQuality"
        RenderOptions.EdgeMode="Aliased">
    
    <Window.Resources>
        <converters:PageIndexToBrushConverter x:Key="PageIndexToBrushConverter"/>
    </Window.Resources>
    
    <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="IslandScaleTransform" ScaleX="0.375" ScaleY="0.2"/>
                <TranslateTransform x:Name="IslandTranslateTransform" Y="0"/>
            </TransformGroup>
        </Grid.RenderTransform>
        
        <Border x:Name="MainBorder"
                Width="400"
                Height="200"
                CornerRadius="22"
                BorderThickness="1"
                ClipToBounds="True">
            <!-- Glassmorphism Background -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#E61A1A1A" Offset="0"/>
                    <GradientStop Color="#E6202020" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            
            <!-- Subtle border glow -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#55FFFFFF" Offset="0"/>
                    <GradientStop Color="#22FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#552D9CDB" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            
            <!-- Enhanced drop shadow -->
            <Border.Effect>
                <DropShadowEffect Color="#000000" 
                                BlurRadius="30" 
                                ShadowDepth="0" 
                                Opacity="0.6"/>
            </Border.Effect>
            
            <Grid x:Name="ContentGrid"
                  Width="400"
                  Height="200"
                  ClipToBounds="True"
                  IsManipulationEnabled="True"
                  ManipulationDelta="ContentGrid_ManipulationDelta"
                  PreviewMouseWheel="ContentGrid_PreviewMouseWheel">
                <!-- Collapsed State Content -->
                <StackPanel x:Name="CollapsedContent" 
                           Orientation="Horizontal"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           Opacity="1"
                           RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <ScaleTransform x:Name="CollapsedContentScale" ScaleX="2.667" ScaleY="5.0"/>
                    </StackPanel.RenderTransform>
                    <TextBlock Text="{Binding SystemInfo.FormattedTime}"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              FontFamily="Space Grotesk"
                              FontSize="13"
                              FontWeight="SemiBold"
                              Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SystemInfo.Temperature, StringFormat={}{0:0}°}"
                              Foreground="{StaticResource SecondaryTextBrush}"
                              FontFamily="Space Grotesk"
                              FontSize="13"
                              Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SystemInfo.BatteryPercentage, StringFormat={}{0}%}"
                              Foreground="{StaticResource SecondaryTextBrush}"
                              FontFamily="Space Grotesk"
                              FontSize="13"/>
                </StackPanel>
                
                <!-- Expanded State Content -->
                <Grid x:Name="ExpandedContent" Visibility="Collapsed" Opacity="0">
                    <!-- Page Container -->
                    <Grid x:Name="PageContainer" Margin="15">
                        
                        <!-- Page 1: System Overview -->
                        <StackPanel x:Name="Page1" Visibility="Visible" RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </StackPanel.RenderTransform>
                            <TextBlock Text="{Binding SystemInfo.FormattedTime}"
                                      Foreground="{StaticResource PrimaryTextBrush}"
                                      FontFamily="Space Grotesk"
                                      FontSize="36"
                                      FontWeight="Light"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.FormattedDate}"
                                      Foreground="{StaticResource SecondaryTextBrush}"
                                      FontFamily="Space Grotesk"
                                      FontSize="13"
                                      FontWeight="Normal"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,20"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <StackPanel Margin="10,0">
                                    <TextBlock Text="Weather"
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="10"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SystemInfo.Temperature, StringFormat={}{0:0}°C}"
                                              Foreground="{StaticResource PrimaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="20"
                                              FontWeight="SemiBold"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="10,0">
                                    <TextBlock Text="Battery"
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="10"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SystemInfo.BatteryPercentage, StringFormat={}{0}%}"
                                              Foreground="{StaticResource PrimaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="20"
                                              FontWeight="SemiBold"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="10,0">
                                    <TextBlock Text="CPU"
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="10"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SystemInfo.CpuUsage, StringFormat={}{0:0}%}"
                                              Foreground="{StaticResource PrimaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="20"
                                              FontWeight="SemiBold"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="10,0">
                                    <TextBlock Text="Network"
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="10"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,6"/>
                    <TextBlock Text="On"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              FontFamily="Space Grotesk"
                              FontSize="20"
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"
                              Visibility="{Binding SystemInfo.IsNetworkAvailable, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="Off"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              FontFamily="Space Grotesk"
                              FontSize="20"
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"
                              Visibility="{Binding SystemInfo.IsNetworkAvailable, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Page 2: Media Context -->
                        <StackPanel x:Name="Page2" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </StackPanel.RenderTransform>
                            <TextBlock Text="No Media Playing"
                                      Foreground="{StaticResource TertiaryTextBrush}"
                                      FontFamily="Space Grotesk"
                                      FontSize="13"
                                      FontWeight="Normal"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="0,70,0,0"
                                      Visibility="{Binding MediaInfo.IsAvailable, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            
                            <Grid Visibility="{Binding MediaInfo.IsAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Album Art -->
                                <Border Grid.Column="0"
                                       Width="80"
                                       Height="80"
                                       CornerRadius="8"
                                       Background="{StaticResource SecondaryBackgroundBrush}"
                                       Margin="0,0,12,0"
                                       ClipToBounds="True">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                    </Border.Effect>
                                    
                                    <Grid>
                                        <!-- Album Art Image -->
                                        <Image Source="{Binding MediaInfo.AlbumArt, Converter={StaticResource Base64ToImageConverter}}"
                                              Stretch="UniformToFill"
                                              Visibility="{Binding MediaInfo.AlbumArt, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>
                                        
                                        <!-- Placeholder Icon when no album art -->
                                        <Viewbox Width="40" Height="40"
                                                Visibility="{Binding MediaInfo.AlbumArt, Converter={StaticResource InverseStringNullOrEmptyToVisibilityConverter}}">
                                            <Path Data="M12 3v9.28c-.47-.17-.97-.28-1.5-.28C8.01 12 6 14.01 6 16.5S8.01 21 10.5 21c2.31 0 4.2-1.75 4.45-4H15V6h4V3h-7z"
                                                 Fill="{StaticResource TertiaryTextBrush}"
                                                 Stretch="Uniform"/>
                                        </Viewbox>
                                    </Grid>
                                </Border>
                                
                                <!-- Media Info and Controls -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <!-- Title and Artist -->
                                    <TextBlock Text="{Binding MediaInfo.Title}"
                                              Foreground="{StaticResource PrimaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              TextTrimming="CharacterEllipsis"
                                              Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding MediaInfo.Artist}"
                                              Foreground="{StaticResource SecondaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="11"
                                              FontWeight="Normal"
                                              TextTrimming="CharacterEllipsis"
                                              Margin="0,0,0,10"/>
                                    
                                    <!-- Playback Controls -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <!-- Previous Button -->
                                        <Button x:Name="PreviousButton"
                                               Width="32"
                                               Height="32"
                                               Background="{StaticResource SecondaryBackgroundBrush}"
                                               BorderBrush="{StaticResource BorderBrush}"
                                               BorderThickness="1.5"
                                               Margin="0,0,8,0"
                                               Cursor="Hand"
                                               Click="MediaPrevious_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="16"/>
                                                </Style>
                                            </Button.Resources>
                                            <Viewbox Width="18" Height="18">
                                                <TextBlock Text=""
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Viewbox>
                                        </Button>
                                        
                                        <!-- Play/Pause Button -->
                                        <Button x:Name="PlayPauseButton"
                                               Width="40"
                                               Height="40"
                                               Background="{StaticResource AccentBrush}"
                                               BorderThickness="0"
                                               Margin="0,0,8,0"
                                               Cursor="Hand"
                                               Click="MediaPlayPause_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="20"/>
                                                </Style>
                                            </Button.Resources>
                                            <Button.Effect>
                                                <DropShadowEffect Color="#2D9CDB" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                                            </Button.Effect>
                                            
                                            <Grid>
                                                <!-- Play Icon -->
                                                <Viewbox Width="20" Height="20"
                                                        Visibility="{Binding MediaInfo.IsPlaying, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                    <TextBlock Text=""
                                                               FontFamily="Segoe MDL2 Assets"
                                                               Foreground="#FFFFFF"
                                                               FontSize="20"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                </Viewbox>
                                                
                                                <!-- Pause Icon -->
                                                <Viewbox Width="20" Height="20"
                                                        Visibility="{Binding MediaInfo.IsPlaying, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text=""
                                                               FontFamily="Segoe MDL2 Assets"
                                                               Foreground="#FFFFFF"
                                                               FontSize="20"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                </Viewbox>
                                            </Grid>
                                        </Button>
                                        
                                        <!-- Next Button -->
                                        <Button x:Name="NextButton"
                                               Width="32"
                                               Height="32"
                                               Background="{StaticResource SecondaryBackgroundBrush}"
                                               BorderBrush="{StaticResource BorderBrush}"
                                               BorderThickness="1.5"
                                               Cursor="Hand"
                                               Click="MediaNext_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="16"/>
                                                </Style>
                                            </Button.Resources>
                                            <Viewbox Width="18" Height="18">
                                                <TextBlock Text=""
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Viewbox>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Progress Bar (Full Width) -->
                            <StackPanel Visibility="{Binding MediaInfo.IsAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Margin="0,12,0,0">
                                <Border Background="{StaticResource SecondaryBackgroundBrush}"
                                       Height="4"
                                       CornerRadius="2"
                                       Margin="0,0,0,6">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                    <Rectangle Fill="{StaticResource AccentBrush}"
                                              HorizontalAlignment="Left"
                                              RadiusX="2"
                                              RadiusY="2">
                                        <Rectangle.Effect>
                                            <DropShadowEffect Color="#2D9CDB" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                        </Rectangle.Effect>
                                        <Rectangle.Width>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:PercentageWidthConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="MediaInfo.ProgressPercentage"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </Rectangle.Width>
                                    </Rectangle>
                                </Border>
                                
                                <!-- Time Display -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                              Text="{Binding MediaInfo.FormattedPosition}"
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="9"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1"
                                              Text="{Binding MediaInfo.FormattedDuration}"
                                              Foreground="{StaticResource TertiaryTextBrush}"
                                              FontFamily="Space Grotesk"
                                              FontSize="9"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Page 3: AI Chat -->
                        <Grid x:Name="Page3" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <!-- Header: label + delete button -->
                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="✦"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="Space Grotesk"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0"/>
                                    <TextBlock Text="AI Chat"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               FontFamily="Space Grotesk"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="DeleteChatButton"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Width="22" Height="18"
                                        Cursor="Hand"
                                        ToolTip="Clear chat"
                                        Click="DeleteChat_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#666666"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="FontFamily" Value="Space Grotesk"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="3,1">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#FF5555"/>
                                                    <Setter Property="Background" Value="#2A1515"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="✕" FontSize="11" FontFamily="Space Grotesk"/>
                                </Button>
                            </Grid>

                            <!-- Chat history -->
                            <ScrollViewer x:Name="ChatScrollViewer"
                                          Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          Margin="0,0,0,6">
                                <ItemsControl ItemsSource="{Binding ChatMessages}">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Border x:Name="Bubble"
                                                        MaxWidth="230"
                                                        Padding="8,5"
                                                        CornerRadius="8"
                                                        HorizontalAlignment="Right"
                                                        Background="#1D3D6B">
                                                    <TextBlock x:Name="BubbleText"
                                                               Text="{Binding Content}"
                                                               FontFamily="Space Grotesk"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Foreground="#FFFFFF"/>
                                                </Border>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Left"/>
                                                    <Setter TargetName="Bubble" Property="Background" Value="#2E2E2E"/>
                                                    <Setter TargetName="BubbleText" Property="Foreground" Value="#CCCCCC"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Input box -->
                            <TextBox x:Name="AIInputBox"
                                     Grid.Row="2"
                                     Background="#242424"
                                     Foreground="#FFFFFF"
                                     BorderBrush="#3A3A3A"
                                     BorderThickness="1.5"
                                     Padding="10,0"
                                     FontSize="12"
                                     FontFamily="Space Grotesk"
                                     CaretBrush="#2D9CDB"
                                     SelectionBrush="#2D9CDB"
                                     VerticalContentAlignment="Center"
                                     KeyDown="AIInputBox_KeyDown">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </Grid>
                        
                        <!-- Page 4: Task Memory -->
                        <Grid x:Name="Page4" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <StackPanel>
                                <TextBox x:Name="TaskInputBox"
                                        Background="#242424"
                                        Foreground="#FFFFFF"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1.5"
                                        Padding="14,12"
                                        FontSize="13"
                                        FontFamily="Space Grotesk"
                                        CaretBrush="#2D9CDB"
                                        SelectionBrush="#2D9CDB"
                                        VerticalContentAlignment="Center"
                                        Height="45"
                                        Margin="0,0,0,12"
                                        KeyDown="TaskInputBox_KeyDown">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <ScrollViewer Height="140" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Tasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                                    <CheckBox IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                                             Style="{StaticResource ModernCheckBox}"
                                                             VerticalAlignment="Center"
                                                             Click="TaskCheckBox_Click"/>
                                                    <TextBlock Text="{Binding Content}"
                                                              Foreground="{StaticResource PrimaryTextBrush}"
                                                              FontFamily="Space Grotesk"
                                                              FontSize="11"
                                                              FontWeight="Normal"
                                                              Margin="5,0"
                                                              VerticalAlignment="Center"
                                                              TextWrapping="Wrap"
                                                              TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethroughConverter}}"/>
                                                    <Button Content="×"
                                                           Style="{StaticResource ModernDeleteButton}"
                                                           Click="RemoveTask_Click"
                                                           Tag="{Binding Id}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Page 5: Clipboard Memory -->
                        <Grid x:Name="Page5" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ClipboardItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ModernClipboardItem}"
                                                   MouseDown="ClipboardItem_MouseDown"
                                                   Tag="{Binding Content}">
                                                <TextBlock Text="{Binding Preview}"
                                                          Foreground="{StaticResource PrimaryTextBrush}"
                                                          FontFamily="Space Grotesk"
                                                          FontSize="11"
                                                          FontWeight="Normal"
                                                          TextWrapping="Wrap"
                                                          LineHeight="16"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                        
                        <!-- Page 6: Settings -->
                        <ScrollViewer x:Name="Page6" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" RenderTransformOrigin="0.5,0.5">
                            <ScrollViewer.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </ScrollViewer.RenderTransform>
                            <StackPanel>
                                <TextBlock Text="AI Settings" 
                                          Foreground="{StaticResource PrimaryTextBrush}"
                                          FontFamily="Space Grotesk"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,12"/>
                                <TextBlock Text="Model:" 
                                          Foreground="{StaticResource TertiaryTextBrush}"
                                          FontFamily="Space Grotesk"
                                          FontSize="10"
                                          FontWeight="Medium"
                                          Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Settings.OpenRouterModel, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#242424"
                                        Foreground="#FFFFFF"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1.5"
                                        Padding="14,12"
                                        FontSize="13"
                                        FontFamily="Space Grotesk"
                                        CaretBrush="#2D9CDB"
                                        SelectionBrush="#2D9CDB"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,12">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <TextBlock Text="API Key:" 
                                          Foreground="{StaticResource TertiaryTextBrush}"
                                          FontFamily="Space Grotesk"
                                          FontSize="10"
                                          FontWeight="Medium"
                                          Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Settings.OpenRouterApiKey, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#242424"
                                        Foreground="#FFFFFF"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1.5"
                                        Padding="14,12"
                                        FontSize="13"
                                        FontFamily="Space Grotesk"
                                        CaretBrush="#2D9CDB"
                                        SelectionBrush="#2D9CDB"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,18">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                
                                <TextBlock Text="Weather Settings" 
                                          Foreground="{StaticResource PrimaryTextBrush}"
                                          FontFamily="Space Grotesk"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,12"/>
                                <TextBlock Text="City:" 
                                          Foreground="{StaticResource TertiaryTextBrush}"
                                          FontFamily="Space Grotesk"
                                          FontSize="10"
                                          FontWeight="Medium"
                                          Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Settings.City, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#242424"
                                        Foreground="#FFFFFF"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1.5"
                                        Padding="14,12"
                                        FontSize="13"
                                        FontFamily="Space Grotesk"
                                        CaretBrush="#2D9CDB"
                                        SelectionBrush="#2D9CDB"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,18">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <TextBlock Text="Clipboard History" 
                                          Foreground="{StaticResource PrimaryTextBrush}"
                                          FontFamily="Space Grotesk"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,12"/>
                                <TextBlock Text="Items to keep:" 
                                          Foreground="{StaticResource TertiaryTextBrush}"
                                          FontFamily="Space Grotesk"
                                          FontSize="10"
                                          FontWeight="Medium"
                                          Margin="0,0,0,6"/>
                                <ComboBox SelectedValue="{Binding Settings.ClipboardHistoryLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          Background="#242424"
                                          Foreground="#FFFFFF"
                                          BorderBrush="#3A3A3A"
                                          BorderThickness="1.5"
                                          Padding="14,12"
                                          FontSize="13"
                                          FontFamily="Space Grotesk"
                                          Height="45"
                                          Margin="0,0,0,18">
                                    <ComboBox.Resources>
                                        <!-- Rounded border & dark popup background -->
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#242424"/>
                                    </ComboBox.Resources>
                                    <ComboBox.Template>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Toggle button surface -->
                                                <ToggleButton x:Name="ToggleButton"
                                                              Grid.ColumnSpan="2"
                                                              Background="{TemplateBinding Background}"
                                                              BorderBrush="{TemplateBinding BorderBrush}"
                                                              BorderThickness="{TemplateBinding BorderThickness}"
                                                              Focusable="False"
                                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                              Cursor="Hand">
                                                    <Grid>
                                                        <Border x:Name="Border"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="8"
                                                                SnapsToDevicePixels="True">
                                                            <ContentPresenter Margin="8,2,26,2"
                                                                              VerticalAlignment="Center"
                                                                              HorizontalAlignment="Left"
                                                                              IsHitTestVisible="False"
                                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                                                        </Border>
                                                        <!-- Chevron icon -->
                                                        <TextBlock Margin="0,0,10,0"
                                                                   Text=""
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="#7A7A7A"/>
                                                    </Grid>
                                                </ToggleButton>

                                                <!-- Popup -->
                                                <Popup x:Name="Popup"
                                                       Grid.ColumnSpan="2"
                                                       Placement="Bottom"
                                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                                       AllowsTransparency="True"
                                                       Focusable="False"
                                                       PopupAnimation="Slide">
                                                    <Border Margin="0,4,0,0"
                                                            Background="#242424"
                                                            BorderBrush="#3A3A3A"
                                                            BorderThickness="1.5"
                                                            CornerRadius="8">
                                                        <ScrollViewer Margin="0"
                                                                      SnapsToDevicePixels="True">
                                                            <StackPanel IsItemsHost="True"
                                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#4A4A4A"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ComboBox.Template>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Background" Value="#242424"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                            <Setter Property="Padding" Value="6,4"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2E2E2E"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#2D9CDB"/>
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBoxItem Content="2" Tag="2"/>
                                    <ComboBoxItem Content="5" Tag="5"/>
                                    <ComboBoxItem Content="10" Tag="10"/>
                                </ComboBox>

                                <TextBlock Text="Startup" 
                                          Foreground="{StaticResource PrimaryTextBrush}"
                                          FontFamily="Space Grotesk"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,12"/>
                                <CheckBox Content="Run Woobly when Windows starts"
                                          IsChecked="{Binding Settings.RunOnStartup, Mode=TwoWay}"
                                          Style="{StaticResource ModernCheckBox}"
                                          Margin="0,0,0,18"/>
                                
                                <Button Content="Save Settings"
                                       Background="#2D9CDB"
                                       Foreground="#FFFFFF"
                                       BorderThickness="0"
                                       Padding="20,12"
                                       FontSize="13"
                                       FontFamily="Space Grotesk"
                                       FontWeight="Medium"
                                       Cursor="Hand"
                                       Click="SaveSettings_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </Button.Resources>
                                    <Button.Effect>
                                        <DropShadowEffect Color="#2D9CDB" BlurRadius="16" ShadowDepth="0" Opacity="0.35"/>
                                    </Button.Effect>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                        
                    </Grid>
                    
                    <!-- Page Navigation Dots -->
                    <StackPanel Orientation="Horizontal" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,10">
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=0}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect x:Name="Dot0Glow" 
                                                Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=1}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="1"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=2}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="2"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=3}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="3"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=4}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="4"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=5}"
                                MouseLeftButtonDown="PageDot_Click" 
                                MouseEnter="PageDot_MouseEnter"
                                MouseLeave="PageDot_MouseLeave"
                                Tag="5"
                                RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2D9CDB" 
                                                BlurRadius="8" 
                                                ShadowDepth="0" 
                                                Opacity="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </StackPanel>

                    <!-- ═══ Call Overlay ══════════════════════════════════════════════════
                         Covers the full expanded island when a WhatsApp / Telegram call
                         is detected. Auto-shown/hidden by OnCallStarted / OnCallEnded.
                    ──────────────────────────────────────────────────────────────────── -->
                    <Grid Visibility="{Binding ActiveCall.IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                          ClipToBounds="True">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#F21A1A1A" Offset="0"/>
                                <GradientStop Color="#F2141A14" Offset="1"/>
                            </LinearGradientBrush>
                        </Grid.Background>

                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Margin="24,0">

                            <!-- Dot + app source row -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,10">
                                <Ellipse Width="8" Height="8"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="#34C759"/>
                                    </Ellipse.Fill>
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform x:Name="CallOverlayDotScale" ScaleX="1" ScaleY="1"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Ellipse.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="CallOverlayDotScale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     From="1" To="1.7" Duration="0:0:0.8"
                                                                     AutoReverse="True"/>
                                                    <DoubleAnimation Storyboard.TargetName="CallOverlayDotScale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     From="1" To="1.7" Duration="0:0:0.8"
                                                                     AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="{Binding ActiveCall.AppSource}"
                                           Foreground="#34C759"
                                           FontFamily="Space Grotesk"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Contact name (shown when available) -->
                            <TextBlock Text="{Binding ActiveCall.ContactName}"
                                       Visibility="{Binding ActiveCall.ContactName, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontFamily="Space Grotesk"
                                       FontSize="26"
                                       FontWeight="Light"
                                       HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="360"
                                       Margin="0,0,0,4"/>

                            <!-- Fallback when no name could be extracted -->
                            <TextBlock Text="Unknown"
                                       Visibility="{Binding ActiveCall.ContactName, Converter={StaticResource InverseStringNullOrEmptyToVisibilityConverter}}"
                                       Foreground="{StaticResource TertiaryTextBrush}"
                                       FontFamily="Space Grotesk"
                                       FontSize="26"
                                       FontWeight="Light"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>

                            <!-- Direction label -->
                            <TextBlock Text="{Binding ActiveCall.DirectionLabel}"
                                       Foreground="{StaticResource TertiaryTextBrush}"
                                       FontFamily="Space Grotesk"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,18"/>

                            <!-- Open app button -->
                            <Border Background="#22FFFFFF"
                                    CornerRadius="10"
                                    Padding="16,6"
                                    HorizontalAlignment="Center"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="CallBanner_Click">
                                <TextBlock Text="Open app"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontFamily="Space Grotesk"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>
                            </Border>

                        </StackPanel>
                    </Grid>
                    <!-- ─────────────────────────────────────────────────────────────── -->

                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
