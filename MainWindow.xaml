<Window x:Class="Woobly.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Woobly"
        xmlns:converters="clr-namespace:Woobly.Converters"
        mc:Ignorable="d"
        Title="Woobly"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="150"
        Height="40"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <converters:PageIndexToBrushConverter x:Key="PageIndexToBrushConverter"/>
        <converters:BoolToStrikethroughConverter x:Key="BoolToStrikethroughConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        
        <!-- Storyboards for expand/collapse animations -->
        <Storyboard x:Key="ExpandAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Width"
                           To="400"
                           Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Height"
                           To="200"
                           Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <Storyboard x:Key="CollapseAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Width"
                           To="150"
                           Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Height"
                           To="40"
                           Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    
    <Grid>
        <Border x:Name="MainBorder"
                Background="#1E1E1E"
                CornerRadius="20"
                BorderBrush="#333333"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" 
                                BlurRadius="20" 
                                ShadowDepth="0" 
                                Opacity="0.5"/>
            </Border.Effect>
            
            <Grid x:Name="ContentGrid" ClipToBounds="True">
                <!-- Collapsed State Content -->
                <StackPanel x:Name="CollapsedContent" 
                           Orientation="Horizontal"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="10,0">
                    <TextBlock Text="{Binding SystemInfo.FormattedTime}"
                              Foreground="White"
                              FontSize="12"
                              FontWeight="SemiBold"
                              Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding SystemInfo.Temperature, StringFormat={}{0:0}°}"
                              Foreground="#AAAAAA"
                              FontSize="12"
                              Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding SystemInfo.BatteryPercentage, StringFormat={}{0}%}"
                              Foreground="#AAAAAA"
                              FontSize="12"/>
                </StackPanel>
                
                <!-- Expanded State Content -->
                <Grid x:Name="ExpandedContent" Visibility="Collapsed">
                    <!-- Page Container -->
                    <Grid x:Name="PageContainer" Margin="15">
                        
                        <!-- Page 1: System Overview -->
                        <StackPanel x:Name="Page1" Visibility="Visible">
                            <TextBlock Text="{Binding SystemInfo.FormattedTime}"
                                      Foreground="White"
                                      FontSize="32"
                                      FontWeight="Bold"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SystemInfo.FormattedDate}"
                                      Foreground="#AAAAAA"
                                      FontSize="14"
                                      HorizontalAlignment="Center"
                                      Margin="0,5,0,15"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <StackPanel Margin="10,0">
                                    <TextBlock Text="Weather"
                                              Foreground="#888888"
                                              FontSize="10"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SystemInfo.Temperature, StringFormat={}{0:0}°C}"
                                              Foreground="White"
                                              FontSize="18"
                                              FontWeight="SemiBold"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="10,0">
                                    <TextBlock Text="Battery"
                                              Foreground="#888888"
                                              FontSize="10"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SystemInfo.BatteryPercentage, StringFormat={}{0}%}"
                                              Foreground="White"
                                              FontSize="18"
                                              FontWeight="SemiBold"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Page 2: Media Context -->
                        <StackPanel x:Name="Page2" Visibility="Collapsed">
                            <TextBlock Text="No Media Playing"
                                      Foreground="#888888"
                                      FontSize="14"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="0,70,0,0"
                                      Visibility="{Binding MediaInfo.IsAvailable, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            
                            <StackPanel Visibility="{Binding MediaInfo.IsAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding MediaInfo.Title}"
                                          Foreground="White"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          TextTrimming="CharacterEllipsis"
                                          HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding MediaInfo.Artist}"
                                          Foreground="#AAAAAA"
                                          FontSize="12"
                                          TextTrimming="CharacterEllipsis"
                                          HorizontalAlignment="Center"
                                          Margin="0,2"/>
                                <ProgressBar Value="{Binding MediaInfo.ProgressPercentage, Mode=OneWay}"
                                           Height="4"
                                           Margin="0,10"
                                           Foreground="#555555"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding MediaInfo.FormattedPosition}"
                                              Foreground="#888888"
                                              FontSize="10"/>
                                    <TextBlock Text=" / "
                                              Foreground="#888888"
                                              FontSize="10"/>
                                    <TextBlock Text="{Binding MediaInfo.FormattedDuration}"
                                              Foreground="#888888"
                                              FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Page 3: AI Response -->
                        <Grid x:Name="Page3" Visibility="Collapsed">
                            <StackPanel>
                                <TextBox x:Name="AIInputBox"
                                        Background="#2A2A2A"
                                        Foreground="White"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                        Padding="8"
                                        FontSize="12"
                                        TextWrapping="Wrap"
                                        Height="40"
                                        Margin="0,0,0,10"
                                        KeyDown="AIInputBox_KeyDown"/>
                                <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding AIResponse}"
                                              Foreground="#CCCCCC"
                                              FontSize="11"
                                              TextWrapping="Wrap"
                                              Padding="5"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Page 4: Task Memory -->
                        <Grid x:Name="Page4" Visibility="Collapsed">
                            <StackPanel>
                                <TextBox x:Name="TaskInputBox"
                                        Background="#2A2A2A"
                                        Foreground="White"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                        Padding="8"
                                        FontSize="12"
                                        Margin="0,0,0,10"
                                        KeyDown="TaskInputBox_KeyDown"/>
                                <ScrollViewer Height="140" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Tasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                                    <CheckBox IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                                             Foreground="White"
                                                             VerticalAlignment="Center"
                                                             Click="TaskCheckBox_Click"/>
                                                    <TextBlock Text="{Binding Content}"
                                                              Foreground="White"
                                                              FontSize="11"
                                                              Margin="5,0"
                                                              VerticalAlignment="Center"
                                                              TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethroughConverter}}"/>
                                                    <Button Content="×"
                                                           Background="Transparent"
                                                           Foreground="#888888"
                                                           BorderThickness="0"
                                                           FontSize="16"
                                                           Padding="5,0"
                                                           Click="RemoveTask_Click"
                                                           Tag="{Binding Id}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Page 5: Clipboard Memory -->
                        <Grid x:Name="Page5" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ClipboardItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2A2A2A"
                                                   Margin="0,5"
                                                   Padding="10"
                                                   CornerRadius="5"
                                                   Cursor="Hand"
                                                   MouseDown="ClipboardItem_MouseDown"
                                                   Tag="{Binding Content}">
                                                <TextBlock Text="{Binding Preview}"
                                                          Foreground="White"
                                                          FontSize="11"
                                                          TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                        
                        <!-- Page 6: Settings -->
                        <ScrollViewer x:Name="Page6" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="AI Settings" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock Text="Model:" Foreground="#888888" FontSize="10"/>
                                <TextBox Text="{Binding Settings.OpenRouterModel, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#2A2A2A" Foreground="White" BorderBrush="#444444"
                                        Padding="5" FontSize="10" Margin="0,2,0,5"/>
                                <TextBlock Text="API Key:" Foreground="#888888" FontSize="10"/>
                                <TextBox Text="{Binding Settings.OpenRouterApiKey, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#2A2A2A" Foreground="White" BorderBrush="#444444"
                                        Padding="5" FontSize="10" Margin="0,2,0,10"/>
                                
                                <TextBlock Text="Weather Settings" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,5,0,5"/>
                                <TextBlock Text="City:" Foreground="#888888" FontSize="10"/>
                                <TextBox Text="{Binding Settings.City, UpdateSourceTrigger=PropertyChanged}"
                                        Background="#2A2A2A" Foreground="White" BorderBrush="#444444"
                                        Padding="5" FontSize="10" Margin="0,2,0,10"/>
                                
                                <Button Content="Save Settings"
                                       Background="#0078D4"
                                       Foreground="White"
                                       BorderThickness="0"
                                       Padding="10,5"
                                       Click="SaveSettings_Click"
                                       Margin="0,10,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                        
                    </Grid>
                    
                    <!-- Page Navigation Dots -->
                    <StackPanel Orientation="Horizontal" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,10">
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=0}"
                                MouseLeftButtonDown="PageDot_Click" Tag="0"/>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=1}"
                                MouseLeftButtonDown="PageDot_Click" Tag="1"/>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=2}"
                                MouseLeftButtonDown="PageDot_Click" Tag="2"/>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=3}"
                                MouseLeftButtonDown="PageDot_Click" Tag="3"/>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=4}"
                                MouseLeftButtonDown="PageDot_Click" Tag="4"/>
                        <Ellipse Width="8" Height="8" Margin="4" Cursor="Hand"
                                Fill="{Binding CurrentPageIndex, Converter={StaticResource PageIndexToBrushConverter}, ConverterParameter=5}"
                                MouseLeftButtonDown="PageDot_Click" Tag="5"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
