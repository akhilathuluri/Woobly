# OpenWeather API Configuration
# Developer: Get your free API key from https://openweathermap.org/api
# This file should be renamed to 'appsettings.json' and placed in the project root
# The OpenWeather API key will be loaded automatically at startup

# Replace YOUR_API_KEY_HERE with your actual OpenWeather API key
OPENWEATHER_API_KEY=your_api_key_here

# Example appsettings.json format:
# {
#   "OpenWeatherApiKey": "your_actual_key_here"
# }

